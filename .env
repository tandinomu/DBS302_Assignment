PORT=5000
NODE_ENV=development

# MongoDB replica set connection — includes all 3 nodes for automatic failover
MONGODB_URI=mongodb://admin:adminpass@mongo1:27017,mongo2:27017,mongo3:27017/shopnest?replicaSet=rs0&authSource=admin
MONGODB_DB_NAME=shopnest

# Redis Sentinel — ioredis will auto-discover master and replicas
REDIS_SENTINEL_NAME=mymaster
REDIS_SENTINEL_HOSTS=redis-sentinel1:26379,redis-sentinel2:26380,redis-sentinel3:26381

# JWT
JWT_SECRET=d08efcd1ea055e7686d2da03b54dfa2a0eff31f9bba833d9dc79e01ac2920274494b170e6a562b961732858ac0121ef945de1dfc3041fb6141e0405cdc286786
JWT_EXPIRES_IN=24h

# bcrypt
BCRYPT_SALT_ROUNDS=12

# Cache TTL base in seconds (jitter applied in code: TTL = base ± 10%)
CACHE_TTL=3600

# Rate limiting
RATE_LIMIT_LOGIN=5
RATE_LIMIT_LOGIN_WINDOW=60
RATE_LIMIT_CHECKOUT=3
RATE_LIMIT_CHECKOUT_WINDOW=60
  